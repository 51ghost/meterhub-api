{
  "openapi": "3.0.3",
  "info": {
    "title": "MeterHub API",
    "description": "Utility meter data and energy monitoring",
    "version": "1.0.0",
    "x-category": "Devices",
    "x-long-description": "The MeterHub API provides production-ready utility meter data and energy monitoring. Fully compatible with RapidAPI marketplace, ready for monetization.",
    "x-badges": [
      {
        "name": "production-ready",
        "color": "green"
      },
      {
        "name": "automation",
        "color": "blue"
      }
    ]
  },
  "servers": [
    {
      "url": "https://meterhub-api-production.up.railway.app",
      "description": "Production"
    }
  ],
  "paths": {
    "/v1/search": {
      "get": {
        "summary": "Search data",
        "operationId": "v1_search",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/lookup/{id}": {
      "get": {
        "summary": "Lookup by ID",
        "operationId": "v1_lookup_id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/health": {
      "get": {
        "summary": "Health check",
        "operationId": "v1_health",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}